{
  "name": "hk-route",
  "version": "1.0.0",
  "description": "Smart public transport routing for Hong Kong with real-time bus ETAs",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=scripts/hk-route.cjs --banner:js='#!/usr/bin/env node'",
