  "license": "ISC",
  "bugs": {
    "url": "https://github.com/7ito/hkroute/issues"
  },
  "homepage": "https://github.com/7ito/hkroute#readme",
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "@types/node": "^25.5.0",
    "hk-bus-eta": "^3.7.8",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
